{
  "name": "taskscore",
  "version": "0.1.0",
  "private": true,
  "description": "Hanggliding/paragliding competition track log analysis",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace=pages",
    "build": "npm run build --workspace=pages",
    "deploy": "npm run deploy --workspace=pages",
    "deployments": "wrangler pages deployment list --project-name=taskscore --json | jq .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "get-xcontest-task": "tsx scripts/get-xcontest-task.ts"
  },
  "workspaces": [
    "pages",
    "workers/*"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260109.0",
    "@types/node": "^25.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@turf/bbox": "^7.3.2",
    "@turf/bearing": "^7.3.2",
    "@turf/destination": "^7.3.2",
    "@turf/distance": "^7.3.2",
    "@turf/helpers": "^7.3.2",
    "mapbox-gl": "^3.17.0",
    "threebox-plugin": "^2.2.7"
  }
}
