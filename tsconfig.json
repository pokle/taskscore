{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "pages/src/**/*",
    "workers/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "explorations"
  ]
}
